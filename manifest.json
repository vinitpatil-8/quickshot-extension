{
  "manifest_version": 3,
  "name": "QuickShot",
  "version": "1.0.0",
  "description": "Capture and save screenshots of the current tab.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icn.png",
    "default_title": "QuickShot"
  }
}