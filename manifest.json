{
  "manifest_version": 3,
  "name": "QuickShot",
  "version": "1.0.0",
  "description": "Capture and save screenshots of the current tab.",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "start-screenshot": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Start a QuickShot capture"
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "assets/icn.png",
    "default_title": "QuickShot"
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
